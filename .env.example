# Copy to .env and fill in your values.
# Used by the postgres17-wal and postgres17-wal-restore Docker services.
#
#   cp .env.example .env
#   make wal-build && make docker-up

# ── Required ──────────────────────────────────────────────────────────────────

# Storj access grant — generate via: storj access create
STORJ_ACCESS=your-storj-access-grant-here

# Storj bucket name (must already exist in your Storj project)
STORJ_BUCKET=cloud-dump-wal-test

# ── Optional ──────────────────────────────────────────────────────────────────

# Prefix for WAL files inside the bucket (default: wal_archive)
WAL_PREFIX=wal_archive

# Set to "false" to upload WAL segments uncompressed (default: true = gzip)
# WAL_COMPRESS=false

# Set to "true" to encrypt WAL segments before upload (default: false)
# WAL_ENCRYPT=true

# Encryption passphrase — used when WAL_ENCRYPT=true
# WAL_PASSPHRASE=your-wal-secret

# Path to age public key file inside the container — used when WAL_ENCRYPT=true
# and you prefer key-pair encryption over a passphrase.
# Mount the key file into the container and set the path here.
# WAL_RECIPIENT_KEY=/run/secrets/age.key.pub

# Path to age private key file — used by the restore container for decryption.
# WAL_IDENTITY_KEY=/run/secrets/age.key
